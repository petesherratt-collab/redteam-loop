diff --git a/agents.cli.json b/agents.cli.json
index 30f8880..3e584ab 100644
--- a/agents.cli.json
+++ b/agents.cli.json
@@ -1,5 +1,5 @@
 {
-  "_comment": "True multi-model red team using three LOCAL CLIs. Install + auth each first (see redteam/README.md): claude, gemini (`npm i -g @google/gemini-cli`), codex (`npm i -g @openai/codex`). All three are fed the prompt on stdin (promptVia: stdin) — the most portable form, and required on Windows where multi-line prompts can't be passed safely as arguments. If a tool ever ignores stdin on your platform, switch that agent to `\"promptVia\": \"arg\"` and append the prompt flag (e.g. command [\"gemini\",\"-p\"]).",
+  "_comment": "True multi-model red team using three LOCAL CLIs. Install + auth each first (see README.md): claude; gemini (`npm i -g @google/gemini-cli`, then run `gemini` once to log in OR set GEMINI_API_KEY); codex (`npm i -g @openai/codex`, then `codex login` OR set OPENAI_API_KEY). All three are fed the prompt on stdin (promptVia: stdin) — the most portable form, and required on Windows. `codex exec` needs --skip-git-repo-check to run outside an approved repo. If a tool ever ignores stdin on your platform, switch that agent to `\"promptVia\": \"arg\"` and append the prompt flag (e.g. command [\"gemini\",\"-p\"]).",
   "proposer": {
     "name": "Claude (proposer)",
     "adapter": "cli",
@@ -18,7 +18,7 @@
     {
       "name": "Codex (red team)",
       "adapter": "cli",
-      "command": ["codex", "exec"],
+      "command": ["codex", "exec", "--skip-git-repo-check"],
       "promptVia": "stdin",
       "system": "You are an adversarial reviewer focused on correctness, edge cases, and security. Cite the exact part you mean."
     }
diff --git a/orchestrate.mjs b/orchestrate.mjs
index b801dc0..ad3373d 100644
--- a/orchestrate.mjs
+++ b/orchestrate.mjs
@@ -91,12 +91,16 @@ const ADAPTERS = {
     const prompt = (system ? `${system}\n\n` : "") + user;
     const via = agent.promptVia || "stdin";
     if (via === "arg") cmd.push(prompt);
-    // On Windows the CLIs are .cmd shims, which require a shell to launch.
-    // (Prefer promptVia "stdin" there: a piped prompt is immune to the
-    // argument mangling cmd.exe does to multi-line strings.)
-    const useShell = process.platform === "win32";
+    // On Windows the CLIs are .cmd shims, which can't be spawned directly and
+    // need a shell. Pass the command as a single string (not args array) so we
+    // don't trip Node's DEP0190 shell-arg-concatenation warning. Use
+    // promptVia "stdin" on Windows: a piped prompt is immune to cmd.exe mangling
+    // multi-line strings (and to the same escaping issue).
+    const isWin = process.platform === "win32";
     return await new Promise((res, rej) => {
-      const ps = spawn(cmd[0], cmd.slice(1), { stdio: ["pipe", "pipe", "pipe"], shell: useShell });
+      const ps = isWin
+        ? spawn(cmd.join(" "), { stdio: ["pipe", "pipe", "pipe"], shell: true })
+        : spawn(cmd[0], cmd.slice(1), { stdio: ["pipe", "pipe", "pipe"] });
       let out = "", err = "";
       ps.stdout.on("data", d => (out += d));
       ps.stderr.on("data", d => (err += d));
